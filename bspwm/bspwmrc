#!/bin/sh
# ╔══════════════════════════════════════════════════════════════════════╗
# ║  bspwmrc — Jetson Orin Nano  (1920x1080)                           ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── Autostart ─────────────────────────────────────────────────────
# sxhkd (keybindings — required)
pgrep -x sxhkd > /dev/null || sxhkd &

# picom (compositor — optional, skip if config or binary missing)
if command -v picom > /dev/null 2>&1 && [ -f "$HOME/.config/picom/picom.conf" ]; then
    pgrep -x picom > /dev/null || picom --config "$HOME/.config/picom/picom.conf" &
fi

# polybar (status bar — optional, skip if launch script missing)
if [ -x "$HOME/.config/polybar/launch.sh" ]; then
    "$HOME/.config/polybar/launch.sh" &
fi

# wallpaper
[ -f "$HOME/.fehbg" ] && sh "$HOME/.fehbg" &

# notifications
if command -v dunst > /dev/null 2>&1; then
    pgrep -x dunst > /dev/null || dunst &
fi

# cursor
xsetroot -cursor_name left_ptr &

# ─── Monitors ─────────────────────────────────────────────────────
# Single 1920×1080 display on the Jetson Orin Nano
bspc monitor -d 1 2 3 4 5 6 7 8 9

# ─── Global Settings ──────────────────────────────────────────────
bspc config border_width          2
bspc config window_gap            8
bspc config top_padding           28
bspc config bottom_padding        0
bspc config left_padding          0
bspc config right_padding         0

bspc config split_ratio           0.52
bspc config borderless_monocle    true
bspc config gapless_monocle       true
bspc config single_monocle        false

bspc config focus_follows_pointer true
bspc config pointer_modifier      mod4

# ─── Colors ────────────────────────────────────────────────────────
bspc config normal_border_color   "#44475a"
bspc config active_border_color   "#6272a4"
bspc config focused_border_color  "#bd93f9"
bspc config presel_feedback_color "#ff79c6"

# ─── Rules ─────────────────────────────────────────────────────────
bspc rule -a Firefox              desktop='^2' follow=on
bspc rule -a Code                 desktop='^3' follow=on
bspc rule -a Thunar               desktop='^4' follow=on
bspc rule -a Pavucontrol          state=floating
bspc rule -a Lxappearance         state=floating
bspc rule -a Nm-connection-editor state=floating
bspc rule -a Gpick                state=floating sticky=on
bspc rule -a Screenkey            manage=off

# ─── Jetson-specific: limit compositing overhead (low GPU mem) ────
# If picom is too heavy, uncomment to disable:
# pkill picom
